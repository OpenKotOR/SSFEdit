{
  // Workspace settings aligned to the SSFEdit Delphi 7 project surface.
  "files.associations": {
    "*.dpr": "pascal",
    "*.dpk": "pascal",
    "*.inc": "pascal",
    "*.dfm": "pascal",
    "*.dof": "ini",
    "*.cfg": "ini",
    "*.ddp": "plaintext"
  },
  "files.exclude": {
    "**/*.dcu": true,
    "**/__history": true,
    "**/__recovery": true,
    "**/*.~*": true
  },
  "search.exclude": {
    "**/*.dcu": true,
    "**/*.exe": true,
    "**/__history": true,
    "**/__recovery": true,
    "**/*.~*": true
  },
  "files.watcherExclude": {
    "**/*.dcu": true,
    "**/__history/**": true,
    "**/__recovery/**": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "USSFEdit.dpr": "USSFEdit.dof, USSFEdit.cfg, USSFEdit.res, SSFEdit.exe, USSFEdit.exe",
    "SSFEdit.pas": "SSFEdit.dfm",
    "UEntryForm.pas": "UEntryForm.dfm"
  },
  "terminal.integrated.automationProfile.windows": {
    "path": "cmd.exe",
    "args": [
      "/d",
      "/c"
    ]
  },
  // The codebase targets Delphi 7, but Linux editor assistance still relies on
  // Free Pascal / Lazarus sources when Delphi libraries are unavailable locally.
  "omnipascal.defaultDevelopmentEnvironment": "FreePascal",
  "omnipascal.freePascalSourcePath": "/usr/share/fpcsrc",
  "omnipascal.lazbuildPath": "/usr/bin/lazbuild",
  "omnipascal.searchPath": "/usr/lib64/lazarus/lcl;/usr/lib64/lazarus/lcl/*;/usr/lib64/lazarus/components/lazutils;/usr/lib64/lazarus/components/lazutils/*"
}